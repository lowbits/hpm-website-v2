{#
/**
 * @file
 * View wrapper for the projects listing page.
 * Renders filter links + project grid inside section-container.
 */
#}
<div class="section-container">
    {% if exposed %}
      <nav class="bef-filter-inline mb-8 lg:mb-12" aria-label="{{ 'Filter nach Geschäftsfeld'|t }}">
        {{ exposed }}
      </nav>
    {% endif %}
    {{ rows }}
    {% if pager %}
      {{ pager }}
    {% endif %}
</div>
