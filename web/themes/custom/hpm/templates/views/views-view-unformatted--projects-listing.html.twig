{#
/**
 * @file
 * Unformatted rows for projects listing – renders items in a CSS grid.
 */
#}
<div class="grid grid-cols-1 gap-x-7 gap-y-12 js-element-group
            sm:grid-cols-2 sm:gap-y-14
            md:grid-cols-3
            lg:gap-y-16">
  {% for row in rows %}
    {{ row.content }}
  {% endfor %}
</div>
