{#
/**
 * @file
 * Accordion item – native <details>/<summary> for accessibility.
 * name attribute: only one open at a time.
 * .is-open class on parent drives CSS animations.
 */
#}
{# noinspection TailwindCSS #}
<details{{ attributes.addClass('accordion__box', 'relative', 'border-hpm-darkred', 'border-t-1') }}
  name="accordion-{{ paragraph.parent_id.value }}">
  <summary class="flex items-center gap-10 justify-between py-4 px-3 cursor-pointer list-none
                   [&::-webkit-details-marker]:hidden">
    {% if paragraph.field_headline.value %}
      <h4 class="h4-serif">
        {{ paragraph.field_headline.value }}
      </h4>
    {% endif %}
    <div class="accordion__button w-3 h-5.25 relative transition-transform duration-300 translate-y-px
                [.is-open_&]:-translate-y-0.5 [.is-open_&]:rotate-180">
      {% include '@hpm/images/vectors/accordion-arrow.svg.twig' %}
    </div>
  </summary>

  {% if paragraph.field_text.value %}
    <div class="accordion-body grid grid-rows-[0fr] transition-[grid-template-rows] duration-500
                [.is-open_&]:grid-rows-[1fr]">
      <div class="overflow-hidden">
        <div class="formatted pl-3 pr-10 pb-5">
          {{ paragraph.field_text.value|raw }}
        </div>
      </div>
    </div>
  {% endif %}
</details>
