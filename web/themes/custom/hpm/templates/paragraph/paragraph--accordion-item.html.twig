{#
/**
 * @file
 * Accordion item – JS-driven open/close with slideUp/slideDown.
 */
#}
<div{{ attributes.addClass('accordion__box', 'js-accordion-item', 'relative', 'border-hpm-darkred', 'border-t-1') }}>

  {# accordion head #}
  <div class="js-accordion-head flex items-center gap-10 justify-between py-4 px-3 cursor-pointer">
    {% if paragraph.field_headline.value %}
      <h4 class="h4-serif">
        {{ paragraph.field_headline.value }}
      </h4>
    {% endif %}
    <div class="accordion__button w-3 h-5.25 relative transition-transform duration-300 translate-y-px
                [.is-active_&]:-translate-y-0.5 [.is-active_&]:rotate-180">
      {% include '@hpm/images/vectors/accordion-arrow.svg.twig' %}
    </div>
  </div>

  {# accordion content #}
  {% if paragraph.field_text.value %}
    <div class="js-accordion-content pb-5 hidden formatted pl-3 pr-10">
      {{ paragraph.field_text.value|raw }}
    </div>
  {% endif %}
</div>
