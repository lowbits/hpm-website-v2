{#
/**
 * @file
 * Projects teaser – Flickity slider of manually curated project items.
 *
 * Fields: field_section_title, field_theme, field_items (projects_teaser_item).
 */
#}
{{ attach_library('hpm/slider-teaser') }}
<section{{ attributes.addClass('projects-teaser', 'teaser-slider', 'content-section', 'js-teaser-slider') }}
  {% if theme_css %}data-theme="{{ theme_css }}"{% endif %}>
  <div class="section-container">

    {# Section title #}
    {% if paragraph.field_section_title.value %}
      <div class="section-title flex flex-col gap-5 mb-8 col-span-12
                  sm:mb-12 sm:flex-row sm:items-center sm:justify-between sm:mb-10
                  md:flex-row md:gap-12
                  lg:mb-12
                  xl:items-center">
        <div class="flex flex-col gap-3">
          <h2 class="h3 text-hpm-red">{{ paragraph.field_section_title.value }}</h2>
        </div>
      </div>
    {% endif %}

    <div class="grid grid-cols-12 gap-x-7 gap-y-10">

      {# Slider controls #}
      <div class="col-span-12 flex flex-col-reverse gap-6 relative z-2
                  items-start
                  sm:col-span-8 sm:items-start
                  md:col-span-4 md:items-start md:gap-0 md:mt-0 md:flex-col
                  lg:col-span-3">
        <div class="slider-controls__buttons flex gap-2">
          <button class="slider-button slider-button--previous js-slider-button-prev" type="button">
            <div class="slider-button__icon">
              {% include '@hpm/images/vectors/button-arrow.svg.twig' %}
            </div>
          </button>
          <button class="slider-button slider-button--next js-slider-button-next" type="button">
            <div class="slider-button__icon">
              {% include '@hpm/images/vectors/button-arrow.svg.twig' %}
            </div>
          </button>
        </div>
      </div>

      {# Slider items #}
      <div class="col-span-11
                  sm:col-span-11
                  md:col-span-8
                  lg:col-span-9">
        <div class="teaser-slider carousel">
              {% for ref in paragraph.field_items %}
                {% set item = ref.entity %}
                {% set media = item.field_image.entity %}
                {% set item_credits = media.field_credits.value %}
                {% set item_headline = item.field_headline.value %}
                {% set item_text = item.field_teaser_text.value %}
                {% set item_link = item.field_link.0 %}
                <div class="projects-teaser-item slider-item flex flex-col items-start gap-3
                            sm:gap-5 lg:gap-6">
                  {% if media and media.field_media_image.entity %}
                    <div class="relative w-full">
                      <div class="image-box pt-[66%]">
                        <img src="{{ file_url(media.field_media_image.entity.uri.value) }}"
                             alt="{{ item_headline }}"
                             loading="lazy">
                      </div>
                      {% if item_credits %}
                        <div class="credits text-hpm-darkred-30 absolute origin-bottom-right
                                    -right-0.5 bottom-0 rotate-90">
                          {{ item_credits starts with '©' ? item_credits : '© ' ~ item_credits }}
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                  <div class="flex flex-col gap-4 lg:gap-5">
                    <div class="flex flex-col gap-3">
                      {% if item_headline %}
                        <h3 class="h4-serif text-hpm-red">{{ item_headline }}</h3>
                      {% endif %}
                      {% if item_text %}
                        <div>{{ item_text }}</div>
                      {% endif %}
                    </div>
                    {% if item_link %}
                      <div class="button-container">
                        {% include '@hpm/templates/components/button-link.html.twig' with {
                          url: item_link.url|default('#'),
                          text: item_link.title|default('Zum Projekt'),
                        } only %}
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
