{#
/**
 * @file
 * Footer meta menu — renders in two columns (secondary links + legal links).
 */
#}
{% if items %}
  {% set halfway = (items|length / 2)|round(0, 'ceil') %}
  <div class="grid grid-cols-12 gap-x-5 gap-y-10">
    <div class="js-footer-inner col-span-12 lg:col-span-6 pt-[1.125rem] relative">
      <div class="bg-hpm-red w-[7.5rem] h-[0.0625rem] absolute top-0 left-0"></div>
      <div class="footer__link-container flex flex-col items-start justify-start gap-4 xl:gap-6">
        {% for item in items|slice(0, halfway) %}
          <a href="{{ item.url }}"
             class="text-link font-erato text-[1.0625rem] leading-[1.2] inline-block text-white [&:after]:bg-white">
            <span class="text-link__text">{{ item.title }}</span>
          </a>
        {% endfor %}
      </div>
    </div>
    <div class="js-footer-inner col-span-12 lg:col-span-6 pt-[1.125rem] relative">
      <div class="bg-hpm-red w-[7.5rem] h-[0.0625rem] absolute top-0 left-0"></div>
      <div class="footer__link-container flex flex-col items-start justify-start gap-4 xl:gap-6">
        {% for item in items|slice(halfway) %}
          <a href="{{ item.url }}"
             class="text-link font-erato text-[1.0625rem] leading-[1.2] inline-block text-white [&:after]:bg-white">
            <span class="text-link__text">{{ item.title }}</span>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}
