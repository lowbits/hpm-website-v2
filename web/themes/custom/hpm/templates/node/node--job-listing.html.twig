{{ attach_library('hpm/fade-ins') }}
<article{{ attributes.addClass('node', 'node--job-listing') }}>
  {{ title_prefix }}
  {{ title_suffix }}

  {# Stage Title #}
  <section class="stage-media stage-section">
    <div class="section-container grid grid-cols-1 gap-x-7
                sm:grid-cols-12">
      <div class="flex flex-col items-start gap-3
                  sm:col-span-10 sm:col-start-2
                  lg:col-span-8 lg:col-start-3">
        <h1 class="info text-hpm-red meta-line--red meta-line--medium">
          {{ 'Stellenangebot'|t }}
        </h1>
        <h2 class="h1">{{ label }}</h2>
      </div>
    </div>
  </section>

  {# Paragraphs #}
  {% if content.field_paragraphs|render|trim %}
    {{ content.field_paragraphs }}
  {% endif %}
</article>
